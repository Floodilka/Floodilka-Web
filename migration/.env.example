# Источник (MongoDB)
MONGO_URI=mongodb://localhost:27017/floodilka

# Цель (Cassandra)
CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=floodilka
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra

# S3 (для иконок и вложений)
S3_ENDPOINT=https://s3.regru.cloud
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=floodilka-bucket
# S3_SOURCE_BUCKET= # откуда читать старые файлы (по умолчанию = S3_BUCKET)
# S3_CDN_BUCKET=     # куда писать новые файлы (по умолчанию = S3_BUCKET)

# Опции
DRY_RUN=false
SKIP_PHASES=
START_PHASE=1
