NODE_ENV=development
SELF_HOSTED=false
RELAX_REGISTRATION_RATE_LIMITS=true
DISABLE_RATE_LIMITS=true
FLOODILKA_TEST_MODE=true
FLOODILKA_TEST_TOKEN=integration-token

FLOODILKA_API_PUBLIC_ENDPOINT=http://localhost:8088/api
FLOODILKA_APP_ENDPOINT=http://localhost:8088
FLOODILKA_GATEWAY_ENDPOINT=ws://gateway:8080
FLOODILKA_MEDIA_ENDPOINT=http://media-proxy:8080
FLOODILKA_CDN_ENDPOINT=http://minio:9000/floodilka-cdn
FLOODILKA_MARKETING_ENDPOINT=http://marketing.floodilka.local
FLOODILKA_ADMIN_ENDPOINT=http://admin.floodilka.local
FLOODILKA_PATH_MARKETING=/
FLOODILKA_PATH_ADMIN=/
FLOODILKA_INVITE_ENDPOINT=http://invites.floodilka.local
FLOODILKA_GIFT_ENDPOINT=http://gifts.floodilka.local

FLOODILKA_API_PORT=8080
FLOODILKA_GATEWAY_WS_PORT=8080
FLOODILKA_GATEWAY_RPC_PORT=8081
FLOODILKA_MEDIA_PROXY_PORT=8080
FLOODILKA_ADMIN_PORT=8080
FLOODILKA_MARKETING_PORT=8080
FLOODILKA_GEOIP_PORT=8080

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/floodilka
REDIS_URL=redis://valkey:6379

CASSANDRA_HOSTS=cassandra
CASSANDRA_KEYSPACE=floodilka
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra

FLOODILKA_GATEWAY_RPC_HOST=gateway
FLOODILKA_GATEWAY_RPC_PORT=8081
GATEWAY_RPC_SECRET=integration-gateway-secret
SUDO_MODE_SECRET=integration-sudo-secret

FLOODILKA_MEDIA_PROXY_HOST=media-proxy
MEDIA_PROXY_SECRET_KEY=integration-media-secret

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_BUCKET_CDN=floodilka-cdn
AWS_S3_BUCKET_UPLOADS=floodilka-uploads
AWS_S3_BUCKET_REPORTS=floodilka-reports
AWS_S3_BUCKET_HARVESTS=floodilka-harvests
AWS_S3_BUCKET_DOWNLOADS=floodilka-downloads

PASSKEYS_ENABLED=true
PASSKEY_RP_NAME=Floodilka Integration
PASSKEY_RP_ID=localhost
PASSKEY_ALLOWED_ORIGINS=http://localhost:8088,http://127.0.0.1:8088

EMAIL_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_WEBHOOK_PUBLIC_KEY=
SENDGRID_FROM_EMAIL=integration@example.com
SENDGRID_FROM_NAME=Floodilka

SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

CAPTCHA_ENABLED=false
CAPTCHA_PRIMARY_PROVIDER=none
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

VOICE_ENABLED=true
LIVEKIT_AUTO_CREATE_DUMMY_DATA=true
LIVEKIT_API_KEY=integration_test_key_12345
LIVEKIT_API_SECRET=integration_test_secret_67890_very_long_secret_key_for_testing_purposes_only
LIVEKIT_WEBHOOK_URL=http://api:8080/webhooks/livekit
LIVEKIT_URL=ws://livekit:7880

SEARCH_ENABLED=true
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=masterKey

CLOUDPAYMENTS_ENABLED=true

CLOUDFLARE_PURGE_ENABLED=false
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

CLAMAV_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310

ADMIN_OAUTH2_CLIENT_ID=
ADMIN_OAUTH2_CLIENT_SECRET=
ADMIN_OAUTH2_AUTO_CREATE=false

YOUTUBE_API_KEY=
AUTO_JOIN_INVITE_CODE=
FLOODILKA_OPERATORS_GUILD_ID=

GEOIP_HOST=geoip
GEOIP_PROVIDER=ipinfo
