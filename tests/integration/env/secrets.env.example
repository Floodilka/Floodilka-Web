# Integration Test Secrets
# Copy this file to secrets.env and fill in your actual values
# The secrets.env file is gitignored and will NOT be committed

# CloudPayments (test mode credentials)
CLOUDPAYMENTS_PUBLIC_ID=pk_your_cloudpayments_public_id_here
CLOUDPAYMENTS_API_SECRET=your_cloudpayments_api_secret_here

# CloudPayments Prices (in kopecks)
CLOUDPAYMENTS_PRICE_MONTHLY_RUB=29900
CLOUDPAYMENTS_PRICE_YEARLY_RUB=249900
CLOUDPAYMENTS_PRICE_GIFT_1_MONTH_RUB=29900
CLOUDPAYMENTS_PRICE_GIFT_1_YEAR_RUB=249900

# Klipy API Key (for GIF search tests)
# Get your API key from: https://klipy.com
KLIPY_API_KEY=your_klipy_api_key_here
