:8080 {
	root * /srv/frontend
	encode zstd gzip

	@versionJson path /version.json
	handle @versionJson {
		header Cache-Control "no-cache, no-store"
		file_server
	}

	@errorReporting path /api/tick
	handle @errorReporting {
		rewrite * /api/0/envelope/
		reverse_proxy https://k1.hawk.so {
			header_up Host k1.hawk.so
		}
	}

	# SEO: noindex for auth routes
	@authRoutes path /login /register /verify /reset /wasntme /invite/*
	header @authRoutes X-Robots-Tag "noindex, nofollow"

	# SEO: cache images and fonts
	@staticAssets path_regexp static \.(png|jpg|jpeg|webp|avif|svg|ico|woff2|woff|ttf)$
	header @staticAssets Cache-Control "public, max-age=2592000"

	# SEO: sitemap and robots — short cache for fresh updates
	@seoFiles path /sitemap.xml /robots.txt
	header @seoFiles Cache-Control "public, max-age=3600"

	# SEO: prerender for search engine bots
	# Maps route path to _prerender/{name}.html built at compile time
	map {path} {prerender_file} {
		/          /_prerender/index.html
		/faq       /_prerender/faq.html
		/download  /_prerender/download.html
		/support   /_prerender/support.html
		/privacy   /_prerender/privacy.html
		/terms     /_prerender/terms.html
		/guidelines /_prerender/guidelines.html
		default    ""
	}

	@bot {
		header_regexp User-Agent (?i)(googlebot|yandex|bingbot|mail\.ru_bot|baiduspider|duckduckbot|slurp|facebookexternalhit|twitterbot|linkedinbot|telegrambot|whatsapp|applebot|semrushbot|ahrefsbot|mj12bot)
		not path /assets/* /icons/* /fonts/* /sitemap.xml /robots.txt /manifest.json
		expression `{prerender_file} != ""`
	}
	handle @bot {
		rewrite * {prerender_file}
		file_server
	}

	# Default: serve SPA for regular users
	handle {
		try_files {path} /index.html
		file_server
	}
}
