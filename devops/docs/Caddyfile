:8080 {
	root * /srv/docs
	encode zstd gzip

	@fingerprinted path /_astro/* /pagefind/*
	header @fingerprinted Cache-Control "public, max-age=31536000, immutable"

	@staticAssets path_regexp static \.(png|jpg|jpeg|webp|avif|svg|ico|woff2|woff|ttf)$
	header @staticAssets Cache-Control "public, max-age=2592000"

	@seoFiles path /sitemap-index.xml /sitemap-*.xml /robots.txt
	header @seoFiles Cache-Control "public, max-age=3600"

	handle_errors {
		@404 expression `{http.error.status_code} == 404`
		rewrite @404 /404.html
		file_server
	}

	file_server
}
