# ==========================================
# FLOODILKA BACKEND - DEVELOPMENT CONFIG
# ==========================================
# Этот файл копируется как .env при make setup
# Для production используйте реальные значения
# В Docker Compose env vars перезаписывают значения ниже

# ==========================================
# CASSANDRA
# ==========================================
CASSANDRA_HOSTS=cassandra
CASSANDRA_KEYSPACE=floodilka
CASSANDRA_LOCAL_DC=datacenter1
# CASSANDRA_USERNAME=
# CASSANDRA_PASSWORD=

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://redis:6379

# ==========================================
# EMAIL (SMTP для верификации)
# ==========================================
SMTP_HOST=connect.smtp.bz
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@floodilka.com
SMTP_PASS=ЗАПРОСИТЬ_У_КОМАНДЫ
EMAIL_FROM_ADDRESS=noreply@floodilka.com
EMAIL_FROM_NAME=Floodilka

# ==========================================
# Mobile Push Notifications
# ==========================================
# FCM (Android)
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_PATH=

# APNs (iOS)
APNS_ENABLED=false
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.floodilka.floodilka
APNS_PRODUCTION=false

# ==========================================
# S3 STORAGE (загрузка файлов)
# ==========================================
S3_ENDPOINT=https://s3.regru.cloud
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=floodilka-bucket
